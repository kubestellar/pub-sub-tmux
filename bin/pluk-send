#!/bin/bash
# pluk-send — send commands back to a tmux session via the pub-sub command FIFO
#
# Usage: pluk-send --session <name> --text "some text" [--enter] [--key C-c]
set -euo pipefail

_resolve_script() {
  local src="$1"
  while [ -L "$src" ]; do
    local dir
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")" 2>/dev/null && pwd
}
SCRIPT_DIR="$(_resolve_script "$0")"
[ -z "$SCRIPT_DIR" ] && SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "${SCRIPT_DIR}/../lib/pluk-common.sh" ]; then
  LIB_DIR="${SCRIPT_DIR}/../lib"
elif [ -f "${SCRIPT_DIR}/../lib/pluk/pluk-common.sh" ]; then
  LIB_DIR="${SCRIPT_DIR}/../lib/pluk"
else
  echo "error: cannot find pluk-common.sh" >&2; exit 1
fi

# shellcheck source=../lib/pluk-common.sh
source "${LIB_DIR}/pluk-common.sh"
# shellcheck source=../lib/pluk-json.sh
source "${LIB_DIR}/pluk-json.sh"

SESSION=""
TEXT=""
ENTER="false"
KEY=""

usage() {
  cat <<'EOF'
Usage: pluk-send --session <name> [options]

Options:
  --session <name>  Tmux session name (required)
  --text <string>   Text to send as keystrokes
  --enter           Send Enter after text
  --key <key>       Send a special key (e.g. C-c, Escape, Enter, Down)
  -h, --help        Show this help

The write times out after 5 seconds if no publisher is reading the FIFO.
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session)  SESSION="$2"; shift 2 ;;
    --text)     TEXT="$2"; shift 2 ;;
    --enter)    ENTER="true"; shift ;;
    --key)      KEY="$2"; shift 2 ;;
    -h|--help)  usage ;;
    *)          echo "unknown option: $1" >&2; usage ;;
  esac
done

if [ -z "$SESSION" ]; then
  echo "error: --session is required" >&2
  usage
fi

if [ -z "$TEXT" ] && [ -z "$KEY" ] && [ "$ENTER" != "true" ]; then
  echo "error: --text, --key, or --enter is required" >&2
  usage
fi

CMD_FIFO="$(pluk_cmd_fifo "$SESSION")"

if [ ! -p "$CMD_FIFO" ]; then
  echo "error: no command FIFO for session '$SESSION' at $CMD_FIFO" >&2
  echo "hint: is pluk-publish running for this session?" >&2
  exit 1
fi

SEND_TIMEOUT_SEC=5

_pluk_write_fifo() {
  local msg="$1"
  local lockfile="${CMD_FIFO}.lock"
  if command -v flock &>/dev/null; then
    (
      flock -w "$SEND_TIMEOUT_SEC" 9 || {
        echo "error: could not acquire FIFO lock after ${SEND_TIMEOUT_SEC}s" >&2
        exit 1
      }
      printf '%s\n' "$msg" > "$CMD_FIFO"
    ) 9>"$lockfile"
  else
    printf '%s\n' "$msg" > "$CMD_FIFO" &
    local wpid=$!
    local elapsed=0
    while kill -0 "$wpid" 2>/dev/null; do
      sleep 1
      elapsed=$((elapsed + 1))
      if [ "$elapsed" -ge "$SEND_TIMEOUT_SEC" ]; then
        kill -9 "$wpid" 2>/dev/null
        wait "$wpid" 2>/dev/null
        echo "error: write to FIFO timed out after ${SEND_TIMEOUT_SEC}s — is pluk-publish running?" >&2
        exit 1
      fi
    done
    wait "$wpid" 2>/dev/null
  fi
}

if [ -n "$TEXT" ] || [ "$ENTER" = "true" ]; then
  _pluk_write_fifo "{\"type\":\"send_keys\",\"text\":\"$(json_escape "$TEXT")\",\"enter\":$ENTER}"
elif [ -n "$KEY" ]; then
  _pluk_write_fifo "{\"type\":\"send_special\",\"key\":\"$(json_escape "$KEY")\"}"
fi
