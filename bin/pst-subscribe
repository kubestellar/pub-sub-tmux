#!/bin/bash
# pst-subscribe — subscribe to pub-sub-tmux events
# Tails the JSONL log for a session, with optional type filtering and --since.
#
# Usage: pst-subscribe <session> [--filter type1,type2] [--since 5m] [--last N]
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
LIB_DIR="${SCRIPT_DIR}/../lib"

# shellcheck source=../lib/pst-common.sh
source "${LIB_DIR}/pst-common.sh"

SESSION=""
FILTER=""
SINCE=""
LAST_N=""
FOLLOW="true"

usage() {
  cat <<'EOF'
Usage: pst-subscribe <session> [options]

Options:
  --filter <types>   Comma-separated event types to include
  --since <duration> Only show events from the last N minutes/hours (e.g. 5m, 1h)
  --last <N>         Show last N events then follow
  --no-follow        Print matching events and exit (don't tail)
  -h, --help         Show this help
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --filter)     FILTER="$2"; shift 2 ;;
    --since)      SINCE="$2"; shift 2 ;;
    --last)
      LAST_N="$2"
      if ! echo "$LAST_N" | grep -qE '^[0-9]+$'; then
        echo "error: --last must be a non-negative integer, got '$LAST_N'" >&2
        exit 1
      fi
      shift 2 ;;
    --no-follow)  FOLLOW="false"; shift ;;
    -h|--help)    usage ;;
    -*)           echo "unknown option: $1" >&2; usage ;;
    *)
      if [ -z "$SESSION" ]; then
        SESSION="$1"; shift
      else
        echo "unexpected argument: $1" >&2; usage
      fi
      ;;
  esac
done

if [ -z "$SESSION" ]; then
  echo "error: session name is required" >&2
  usage
fi

LOG_FILE="$(pst_log_file "$SESSION")"

if [ ! -f "$LOG_FILE" ]; then
  echo "error: no log file for session '$SESSION' at $LOG_FILE" >&2
  echo "hint: is pst-publish running for this session?" >&2
  exit 1
fi

_pst_fast_type() {
  echo "$1" | sed -n 's/.*"type"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
}

should_include() {
  local line="$1"
  if [ -n "$SINCE" ] && [ -n "$SINCE_CUTOFF" ]; then
    local ts
    ts=$(echo "$line" | sed -n 's/.*"ts"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
    if [ -n "$ts" ] && [[ ! "$ts" > "$SINCE_CUTOFF" ]]; then
      return 1
    fi
  fi
  if [ -n "$FILTER" ]; then
    local type
    type=$(_pst_fast_type "$line")
    if ! echo ",$FILTER," | grep -q ",$type,"; then
      return 1
    fi
  fi
  return 0
}

SINCE_CUTOFF=""
if [ -n "$SINCE" ]; then
  local_unit="${SINCE: -1}"
  local_val="${SINCE%?}"
  local_seconds=0
  case "$local_unit" in
    s) local_seconds="$local_val" ;;
    m) local_seconds=$((local_val * 60)) ;;
    h) local_seconds=$((local_val * 3600)) ;;
    d) local_seconds=$((local_val * 86400)) ;;
    *) echo "error: invalid --since unit (use s/m/h/d)" >&2; exit 1 ;;
  esac
  SINCE_CUTOFF=$(date -u -d "-${local_seconds} seconds" +%Y-%m-%dT%H:%M:%S 2>/dev/null || \
                 date -u -v-"${local_seconds}"S +%Y-%m-%dT%H:%M:%S 2>/dev/null || echo "")
fi

if [ "$FOLLOW" = "true" ]; then
  TAIL_ARGS=("-f")
  if [ -n "$LAST_N" ]; then
    TAIL_ARGS+=("-n" "$LAST_N")
  else
    TAIL_ARGS+=("-n" "0")
  fi
  tail "${TAIL_ARGS[@]}" "$LOG_FILE" | while IFS= read -r line; do
    should_include "$line" && echo "$line"
  done
else
  if [ -n "$LAST_N" ]; then
    tail -n "$LAST_N" "$LOG_FILE"
  else
    cat "$LOG_FILE"
  fi | while IFS= read -r line; do
    should_include "$line" && echo "$line"
  done
fi
