#!/bin/bash
# pluk-publish — pipe-pane publisher
# Reads tmux pane output from stdin, emits JSONL events to a log file.
#
# Usage: tmux pipe-pane -t "$SESSION" -o "exec pluk-publish --session $SESSION --cli claude"
#        echo "some output" | pluk-publish --session test --cli claude
_resolve_script() {
  local src="$1"
  while [ -L "$src" ]; do
    local dir
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")" 2>/dev/null && pwd
}
SCRIPT_DIR="$(_resolve_script "$0")"
if [ -z "$SCRIPT_DIR" ]; then
  SCRIPT_DIR="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
fi

set -u
cd /tmp 2>/dev/null || true

# Find lib directory: repo layout (../lib/) or installed layout (../lib/pluk/)
if [ -f "${SCRIPT_DIR}/../lib/pluk-common.sh" ]; then
  LIB_DIR="${SCRIPT_DIR}/../lib"
elif [ -f "${SCRIPT_DIR}/../lib/pluk/pluk-common.sh" ]; then
  LIB_DIR="${SCRIPT_DIR}/../lib/pluk"
else
  echo "error: cannot find pluk-common.sh in ../lib/ or ../lib/pluk/" >&2
  exit 1
fi

# shellcheck source=../lib/pluk-common.sh
source "${LIB_DIR}/pluk-common.sh"
# shellcheck source=../lib/pluk-json.sh
source "${LIB_DIR}/pluk-json.sh"
# shellcheck source=../lib/pluk-patterns.sh
source "${LIB_DIR}/pluk-patterns.sh"

SESSION=""
PANE="0"
CLI=""
SOURCE="pipe-pane"
EMIT_RAW="true"

usage() {
  cat <<'EOF'
Usage: pluk-publish --session <name> [--pane <id>] [--cli <name>] [--source <name>] [--no-raw]

Options:
  --session   Tmux session name (required)
  --pane      Tmux pane ID (default: 0)
  --cli       CLI backend name for pattern matching (claude, copilot, gemini, goose)
  --source    Event source tag (default: pipe-pane)
  --no-raw    Suppress raw_output events (only emit classified events)

Environment:
  PLUK_RUN_DIR       Log/FIFO directory (default: /var/run/pluk)
  PLUK_PATTERNS_DIR  Pattern files directory (auto-detected from install path)
  PLUK_KEEP_STDERR   Set to 1 to keep stderr output (default: auto-redirect to /dev/null)
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --session)  SESSION="$2"; shift 2 ;;
    --pane)
      PANE="$2"
      if ! echo "$PANE" | grep -qE '^[0-9]+$'; then
        pst_log "error: --pane must be numeric, got '$PANE'"
        exit 1
      fi
      shift 2 ;;
    --cli)      CLI="$2"; shift 2 ;;
    --source)   SOURCE="$2"; shift 2 ;;
    --no-raw)   EMIT_RAW="false"; shift ;;
    -h|--help)  usage ;;
    *)          pst_log "unknown option: $1"; usage ;;
  esac
done

if [ -z "$SESSION" ]; then
  pst_log "error: --session is required"
  usage
fi

if echo "$SESSION" | grep -qE '[[:space:]/\\:]'; then
  pst_log "warning: session name '$SESSION' contains spaces, slashes, or colons — may cause issues with tmux and file paths"
fi

MAX_SESSION_LEN=200
if [ "${#SESSION}" -gt "$MAX_SESSION_LEN" ]; then
  pst_log "error: session name too long (${#SESSION} chars, max $MAX_SESSION_LEN) — filesystem filename limit"
  exit 1
fi

pluk_ensure_dirs

LOG_FILE="$(pluk_log_file "$SESSION")"
CMD_FIFO="$(pluk_cmd_fifo "$SESSION")"

if [ -d "$LOG_FILE" ]; then
  pst_log "error: log path is a directory: $LOG_FILE"
  exit 1
fi

touch "$LOG_FILE" 2>/dev/null
if [ ! -w "$LOG_FILE" ]; then
  pst_log "error: cannot write to log file: $LOG_FILE"
  exit 1
fi

SEQ=0
if [ -f "$LOG_FILE" ]; then
  LAST_SEQ=$(tail -1 "$LOG_FILE" 2>/dev/null | pluk_json_int_field "seq")
  SEQ="${LAST_SEQ:-0}"
fi

if [ -n "$CLI" ]; then
  if pst_load_patterns "$CLI"; then
    pst_log "loaded patterns for $CLI"
  else
    pst_log "warning: no pattern file for cli=$CLI"
  fi
fi

strip_ansi() {
  perl -pe '
    s/\e\[[0-9;?]*[a-zA-Z]//g;
    s/\e\][^\a]*\a//g;
    s/\e\][^\e]*\e\\//g;
    s/\e[()(B=>\[]//g;
    s/\r//g;
    s/[\x00-\x08\x0b\x0c\x0e-\x1f]//g;
  ' 2>/dev/null || cat
}

pluk_ensure_fifo "$CMD_FIFO"
CMD_READER_PID=""
if [ -p "$CMD_FIFO" ]; then
  (
    local_seq=1000000
    exec 3<>"$CMD_FIFO"
    while IFS= read -r cmd_json <&3; do
      [ -z "$cmd_json" ] && continue
      cmd_type=$(echo "$cmd_json" | pluk_json_field "type")
      case "$cmd_type" in
        send_keys)
          text=$(echo "$cmd_json" | pluk_json_field "text")
          enter=$(echo "$cmd_json" | pluk_json_bool_field "enter")
          [ -n "$text" ] && tmux send-keys -t "$SESSION" -l "$text"
          if [ "$enter" = "true" ]; then
            sleep 0.3
            tmux send-keys -t "$SESSION" Enter
          fi
          local_seq=$((local_seq + 1))
          json_event "$SESSION" "$PANE" "cmd" "$local_seq" "command_received" \
            "{\"text\":$(json_string "$text"),\"sender\":\"pluk-send\"}" >> "$LOG_FILE"
          ;;
        send_special)
          key=$(echo "$cmd_json" | pluk_json_field "key")
          [ -n "$key" ] && tmux send-keys -t "$SESSION" "$key"
          local_seq=$((local_seq + 1))
          json_event "$SESSION" "$PANE" "cmd" "$local_seq" "command_received" \
            "{\"key\":$(json_string "$key"),\"sender\":\"pluk-send\"}" >> "$LOG_FILE"
          ;;
      esac
    done
  ) &
  CMD_READER_PID=$!
fi

cleanup() {
  [ -n "$CMD_READER_PID" ] && kill "$CMD_READER_PID" 2>/dev/null || true
  exit 0
}
trap cleanup TERM INT HUP EXIT

# When running via pipe-pane, stderr goes to the terminal which pipe-pane
# captures, creating a feedback loop. Auto-redirect to /dev/null if stdin
# is not a terminal (i.e., we're receiving piped input).
if [ ! -t 0 ] && [ -z "${PLUK_KEEP_STDERR:-}" ]; then
  exec 2>/dev/null
fi

pst_log "publisher started: session=$SESSION pane=$PANE cli=$CLI source=$SOURCE"

while IFS= read -r raw_line; do
  clean=$(echo "$raw_line" | strip_ansi)
  clean="${clean#"${clean%%[![:space:]]*}"}"
  clean="${clean%"${clean##*[![:space:]]}"}"
  [ -z "$clean" ] && continue

  MAX_LINE_LEN=2000
  if [ "${#clean}" -gt "$MAX_LINE_LEN" ]; then
    clean="${clean:0:$MAX_LINE_LEN}"
  fi

  if [ "$EMIT_RAW" = "true" ]; then
    SEQ=$((SEQ + 1))
    json_event "$SESSION" "$PANE" "$SOURCE" "$SEQ" "raw_output" \
      "{\"line\":$(json_string "$clean")}" >> "$LOG_FILE"
  fi

  if [ -n "$_PST_PATTERNS_LOADED" ]; then
    pst_classify_line "$clean" "$SESSION" "$PANE" "$SOURCE" SEQ >> "$LOG_FILE"
  fi
done
