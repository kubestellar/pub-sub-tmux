#!/bin/bash
# pluk-subscribe — subscribe to pluk events
# Tails the JSONL log for a session, with optional type filtering and --since.
#
# Usage: pluk-subscribe <session> [--filter type1,type2] [--since 5m] [--last N]
set -euo pipefail

_resolve_script() {
  local src="$1"
  while [ -L "$src" ]; do
    local dir
    dir="$(cd "$(dirname "$src")" && pwd)"
    src="$(readlink "$src")"
    [[ "$src" != /* ]] && src="$dir/$src"
  done
  cd "$(dirname "$src")" 2>/dev/null && pwd
}
SCRIPT_DIR="$(_resolve_script "$0")"
[ -z "$SCRIPT_DIR" ] && SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
if [ -f "${SCRIPT_DIR}/../lib/pluk-common.sh" ]; then
  LIB_DIR="${SCRIPT_DIR}/../lib"
elif [ -f "${SCRIPT_DIR}/../lib/pluk/pluk-common.sh" ]; then
  LIB_DIR="${SCRIPT_DIR}/../lib/pluk"
else
  echo "error: cannot find pluk-common.sh" >&2; exit 1
fi

# shellcheck source=../lib/pluk-common.sh
source "${LIB_DIR}/pluk-common.sh"

SESSION=""
FILTER=""
SINCE=""
LAST_N=""
FOLLOW="true"

usage() {
  cat <<'EOF'
Usage: pluk-subscribe <session> [options]

Options:
  --filter <types>   Comma-separated event types to include
  --since <duration> Only show events newer than duration (e.g. 30s, 5m, 1h, 2d)
  --last <N>         Show last N events then follow
  --no-follow        Print matching events and exit (don't tail)
  -h, --help         Show this help

In follow mode, waits up to 30s for the log file to appear if it doesn't exist yet.
EOF
  exit 1
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --filter)     FILTER="$2"; shift 2 ;;
    --since)      SINCE="$2"; shift 2 ;;
    --last)
      LAST_N="$2"
      if ! echo "$LAST_N" | grep -qE '^[0-9]+$'; then
        echo "error: --last must be a non-negative integer, got '$LAST_N'" >&2
        exit 1
      fi
      shift 2 ;;
    --no-follow)  FOLLOW="false"; shift ;;
    -h|--help)    usage ;;
    -*)           echo "unknown option: $1" >&2; usage ;;
    *)
      if [ -z "$SESSION" ]; then
        SESSION="$1"; shift
      else
        echo "unexpected argument: $1" >&2; usage
      fi
      ;;
  esac
done

if [ -z "$SESSION" ]; then
  echo "error: session name is required" >&2
  usage
fi

# Normalize filter: strip whitespace around each type
if [ -n "$FILTER" ]; then
  FILTER=$(echo "$FILTER" | tr ',' '\n' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//' | tr '\n' ',' | sed 's/,$//')
fi

LOG_FILE="$(pluk_log_file "$SESSION")"

if [ ! -f "$LOG_FILE" ]; then
  if [ "$FOLLOW" = "true" ]; then
    echo "waiting for log file: $LOG_FILE" >&2
    PST_WAIT_TIMEOUT=30
    _waited=0
    while [ ! -f "$LOG_FILE" ] && [ "$_waited" -lt "$PST_WAIT_TIMEOUT" ]; do
      sleep 1
      _waited=$((_waited + 1))
    done
    if [ ! -f "$LOG_FILE" ]; then
      echo "error: log file not created after ${PST_WAIT_TIMEOUT}s — is pluk-publish running?" >&2
      exit 1
    fi
    # File just appeared — read from beginning to catch initial events
    if [ -z "$LAST_N" ]; then
      LAST_N="+1"
    fi
  else
    echo "error: no log file for session '$SESSION' at $LOG_FILE" >&2
    echo "hint: is pluk-publish running for this session?" >&2
    exit 1
  fi
fi

_pluk_fast_type() {
  echo "$1" | sed -n 's/.*"type"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p'
}

should_include() {
  local line="$1"
  if [ -n "$SINCE" ] && [ -n "$SINCE_CUTOFF" ]; then
    local ts
    ts=$(echo "$line" | sed -n 's/.*"ts"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')
    # Normalize: strip sub-second precision (.000Z → Z) for consistent comparison
    local ts_norm="$ts"
    if [[ "$ts" == *"."* ]]; then
      ts_norm="${ts%.*}Z"
    fi
    if [ -n "$ts" ] && [[ "$ts_norm" < "$SINCE_CUTOFF" ]]; then
      return 1
    fi
  fi
  if [ -n "$FILTER" ]; then
    local type
    type=$(_pluk_fast_type "$line")
    if ! echo ",$FILTER," | grep -Fq ",$type,"; then
      return 1
    fi
  fi
  return 0
}

SINCE_CUTOFF=""
if [ -n "$SINCE" ]; then
  local_unit="${SINCE: -1}"
  local_val="${SINCE%?}"
  if [ -z "$local_val" ] || ! echo "$local_val" | grep -qE '^[0-9]+$'; then
    echo "error: --since value must be a positive integer followed by s/m/h/d (got '$SINCE')" >&2
    exit 1
  fi
  local_seconds=0
  case "$local_unit" in
    s) local_seconds="$local_val" ;;
    m) local_seconds=$((local_val * 60)) ;;
    h) local_seconds=$((local_val * 3600)) ;;
    d) local_seconds=$((local_val * 86400)) ;;
    *) echo "error: invalid --since unit (use s/m/h/d)" >&2; exit 1 ;;
  esac
  SINCE_CUTOFF=$(date -u -d "-${local_seconds} seconds" +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || \
                 date -u -v-"${local_seconds}"S +%Y-%m-%dT%H:%M:%SZ 2>/dev/null || echo "")
fi

if [ "$FOLLOW" = "true" ]; then
  TAIL_ARGS=("-F")
  if [ -n "$LAST_N" ]; then
    TAIL_ARGS+=("-n" "$LAST_N")
  else
    TAIL_ARGS+=("-n" "0")
  fi
  tail "${TAIL_ARGS[@]}" "$LOG_FILE" | while IFS= read -r line; do
    should_include "$line" && echo "$line"
  done
else
  # Non-follow mode
  if [ -n "$FILTER" ] && [ -z "$SINCE" ]; then
    # Fast path: filter-only uses grep (much faster than per-line sed for large files)
    # Escape regex metacharacters in type names, then build alternation pattern
    _grep_pattern=$(echo "$FILTER" | tr ',' '\n' | sed 's/^[[:space:]]*//; s/[[:space:]]*$//; /^$/d; s/[.[\*^$()+?{|\\]/\\&/g; s/.*/"type":[[:space:]]*"&"/' | tr '\n' '|' | sed 's/|$//')
    if [ -n "$LAST_N" ]; then
      tail -n "$LAST_N" "$LOG_FILE" | grep -E "$_grep_pattern" || true
    else
      grep -E "$_grep_pattern" "$LOG_FILE" || true
    fi
  elif [ -z "$FILTER" ] && [ -z "$SINCE" ]; then
    if [ -n "$LAST_N" ]; then
      tail -n "$LAST_N" "$LOG_FILE"
    else
      cat "$LOG_FILE"
    fi
  else
    if [ -n "$LAST_N" ]; then
      tail -n "$LAST_N" "$LOG_FILE"
    else
      cat "$LOG_FILE"
    fi | while IFS= read -r line; do
      should_include "$line" && echo "$line"
    done
  fi
fi
